// Prisma schema for the Lugiano portal API.
// Datasource: PostgreSQL (Docker, local).
// Client uses Prisma's DEFAULT output (node_modules/@prisma/client) so the native
// query-engine DLL never lands in dist/ — avoids Windows EPERM under nest --watch.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Ported from biostar, tenancy removed. Role + office for Lugiano.
model User {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique
  passwordHash          String
  fullName              String
  role                  UserRole  @default(BILLER)
  office                String?
  isActive              Boolean   @default(true)
  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime?
  createdAt             DateTime  @default(now())
}

enum UserRole {
  ADMIN
  BILLER
  DOCTOR
  ATTORNEY
}
